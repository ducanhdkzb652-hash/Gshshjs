def send_telegram(message: str) -> bool:
    """Gui tin nhan qua Telegram Bot."""
    if not TELEGRAM_TOKEN or not TELEGRAM_CHAT_ID:
        print("Telegram chua cau hinh"); return False
    try:
        r = requests.post(
            f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage",
            json={
                "chat_id":    TELEGRAM_CHAT_ID,
                "text":       message,
                "parse_mode": "HTML"
            }, timeout=5)
        ok = r.status_code == 200
        print(f"Telegram: {'OK' if ok else r.text[:60]}")
        return ok
    except Exception as e:
        print(f"Telegram error: {e}"); return False


def send_sms(phone: str, message: str) -> bool:
    """Gui SMS qua SpeedSMS API."""
    if not SPEEDSMS_TOKEN or not phone:
        print("SpeedSMS chua cau hinh"); return False
    try:
        credentials = base64.b64encode(
            f"{SPEEDSMS_TOKEN}:0".encode()
        ).decode()
        r = requests.post(
            "https://api.speedsms.vn/index.php/sms/send",
            json={
                "to":       [phone],
                "content":  message,
                "sms_type": 2,
                "sender":   SPEEDSMS_SENDER
            },
            headers={
                "Authorization": f"Basic {credentials}",
                "Content-Type":  "application/json"
            }, timeout=5)
        result = r.json()
        ok = result.get("status") == "success"
        print(f"SpeedSMS: {'OK' if ok else result}")
        return ok
    except Exception as e:
        print(f"SpeedSMS error: {e}"); return False


def send_email(subject: str, body: str) -> bool:
    """Gui email qua Gmail."""
    if not GMAIL_USER or not GMAIL_PASS or not GMAIL_TO:
        print("Gmail chua cau hinh"); return False
    try:
        msg            = MIMEText(body, "plain", "utf-8")
        msg["Subject"] = subject
        msg["From"]    = GMAIL_USER
        msg["To"]      = GMAIL_TO
        with smtplib.SMTP_SSL("smtp.gmail.com", 465) as s:
            s.login(GMAIL_USER, GMAIL_PASS)
            s.send_message(msg)
        print("Gmail: OK"); return True
    except Exception as e:
        print(f"Gmail error: {e}"); return False


def notify_all(pname: str, message: str, phone: str = ""):
    """Gui thong bao qua tat ca kenh trong thread rieng."""
    def _send():
        full_msg = (
            f"SepsisAI Alert\n"
            f"Benh nhan: {pname}\n"
            f"{message}\n"
            f"Thoi gian: {datetime.now().strftime('%H:%M %d/%m/%Y')}"
        )
        tele_msg = (
            f"<b>SepsisAI Alert</b>\n"
            f"Benh nhan: <b>{pname}</b>\n"
            f"{message}\n"
            f"Thoi gian: {datetime.now().strftime('%H:%M %d/%m/%Y')}"
        )
        # Telegram (nhanh nhat)
        send_telegram(tele_msg)
        # SpeedSMS
        target = phone or SPEEDSMS_PHONE
        if target:
            send_sms(target, full_msg)
        # Gmail
        send_email(f"SepsisAI Alert - {pname}", full_msg)

    threading.Thread(target=_send, daemon=True).start()

