def init_db():
    con = sqlite3.connect(DB_PATH)
    cur = con.cursor()
    cur.execute("""
        CREATE TABLE IF NOT EXISTS patients (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL, dob TEXT, gender TEXT,
            phone TEXT, address TEXT, note TEXT,
            created TEXT DEFAULT (datetime('now','localtime'))
        )""")
    cur.execute("""
        CREATE TABLE IF NOT EXISTS sessions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            patient_id INTEGER, start_time TEXT, end_time TEXT,
            avg_hr REAL, avg_spo2 REAL, avg_temp REAL,
            risk_rate REAL, conclusion TEXT,
            FOREIGN KEY(patient_id) REFERENCES patients(id)
        )""")
    con.commit(); con.close()

def get_patients():
    con  = sqlite3.connect(DB_PATH)
    rows = con.execute(
        "SELECT id,name,dob,gender,phone FROM patients ORDER BY name"
    ).fetchall()
    con.close(); return rows

def add_patient(name, dob, gender, phone, address, note):
    con = sqlite3.connect(DB_PATH)
    con.execute(
        "INSERT INTO patients(name,dob,gender,phone,address,note) VALUES(?,?,?,?,?,?)",
        (name,dob,gender,phone,address,note))
    con.commit()
    pid = con.execute("SELECT last_insert_rowid()").fetchone()[0]
    con.close(); return pid

def save_session(pid, start, end, avg_hr, avg_spo2, avg_temp, risk_rate, conclusion):
    con = sqlite3.connect(DB_PATH)
    con.execute("""INSERT INTO sessions
        (patient_id,start_time,end_time,avg_hr,avg_spo2,avg_temp,risk_rate,conclusion)
        VALUES(?,?,?,?,?,?,?,?)""",
        (pid,start,end,avg_hr,avg_spo2,avg_temp,risk_rate,conclusion))
    con.commit(); con.close()

def get_sessions(pid):
    con  = sqlite3.connect(DB_PATH)
    rows = con.execute("""SELECT start_time,avg_hr,avg_spo2,avg_temp,risk_rate,conclusion
        FROM sessions WHERE patient_id=?
        ORDER BY start_time DESC LIMIT 20""", (pid,)).fetchall()
    con.close(); return rows

