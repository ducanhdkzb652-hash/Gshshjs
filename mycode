def export_report():
    if len(history) < 10:
        messagebox.showwarning("","Can it nhat 10 mau"); return
    hrs   = [h[1] for h in history]
    spo2s = [h[2] for h in history]
    temps = [h[3] for h in history]
    risks = [h for h in history if h[4]=="RISK"]
    rr    = len(risks)/len(history)*100
    conc  = ("NGUY CO CAO"
             if rr>30 or np.min(spo2s)<90 or np.mean(temps)>=38.3
             else "NGUY CO THAP")
    pinfo = (f"ID:{current_patient[0]} | {current_patient[1]} | SDT:{current_patient[2]}"
             if current_patient else "Khong co ho so")
    report = f"""
AI SEPSIS - BAO CAO LAM SANG
==============================
Ngay      : {datetime.now().strftime('%d/%m/%Y %H:%M')}
Benh nhan : {pinfo}
So mau    : {len(history)}
Baseline  : HR={baseline_engine.baseline['hr']:.0f} SpO2={baseline_engine.baseline['spo2']:.0f} Temp={baseline_engine.baseline['temp']:.1f}

-- Chi So Sinh Ton --
HR   : TB={np.mean(hrs):.1f} Max={np.max(hrs):.1f} Min={np.min(hrs):.1f} bpm
SpO2 : TB={np.mean(spo2s):.1f}% Min={np.min(spo2s):.1f}%
Nhiet: TB={np.mean(temps):.1f}C Max={np.max(temps):.1f}C (GY-906)

-- Phan Tich AI --
Risk Events : {len(risks)} / {len(history)}
Risk Rate   : {rr:.1f}%

-- Ket Luan --
{conc}

Chi ho tro lam sang, khong thay the bac si.
"""
    folder = DATA_DIR
    if current_patient:
        safe   = "".join(c for c in current_patient[1] if c.isalnum() or c in " _-")
        folder = DATA_DIR / f"P{current_patient[0]:04d}_{safe}"
        folder.mkdir(exist_ok=True)
    path = folder / f"report_{int(time.time())}.txt"
    with open(path,"w",encoding="utf-8-sig") as f: f.write(report)
    messagebox.showinfo("OK", f"Da luu:\n{path}")

