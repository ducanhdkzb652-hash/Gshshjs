def update_gui(finger, hr, spo2, ppg, label, conf, temp):
    baseline_var.set(f"Baseline: {baseline_engine.status}")

    if not finger:
        finger_var.set("NO"); ai_var.set("NO FINGER")
        ai_label_w.config(fg=GRAY); timer_var.set("")
        alert_engine.reset_all(); return

    sig = np.array(ppg_buffer) if len(ppg_buffer)==WINDOW else np.zeros(WINDOW)
    pi  = np.std(sig)/(np.mean(sig)+1e-6)*100

    finger_var.set("YES")
    hr_var.set(f"{hr:.0f}")
    spo2_var.set(f"{spo2:.1f}")
    pi_var.set(f"{pi:.2f}")
    conf_var.set(f"Confidence: {conf}%")
    if temp > 25.0 and temp < 45.0:
        temp_var.set(f"{temp:.1f}")

    pname  = current_patient[1] if current_patient else "Unknown"
    pphone = current_patient[2] if current_patient else ""
    alert_msg = None

    if alert_engine.check("spo2_crit", spo2>0 and spo2<90):
        ai_var.set("CRITICAL SpO2"); ai_label_w.config(fg=ACC2)
        alert_msg = f"SpO2 nguy hiem: {spo2:.1f}%"
    elif alert_engine.check("sepsis", temp>=38.3 and hr>100):
        ai_var.set("SEPSIS RISK"); ai_label_w.config(fg=ACC2)
        alert_msg = f"Nghi ngo Sepsis! Temp:{temp:.1f}C HR:{hr:.0f}bpm"
    elif alert_engine.check("tachy", hr>130):
        ai_var.set("TACHYCARDIA"); ai_label_w.config(fg=WARN)
        alert_msg = f"Nhip tim nhanh: {hr:.0f} bpm"
    elif alert_engine.check("brady", 0<hr<50):
        ai_var.set("BRADYCARDIA"); ai_label_w.config(fg=WARN)
        alert_msg = f"Nhip tim cham: {hr:.0f} bpm"
    elif alert_engine.check("hypo_temp", 0<temp<=35.0):
        ai_var.set("HYPOTHERMIA"); ai_label_w.config(fg=WARN)
        alert_msg = f"Ha than nhiet: {temp:.1f}C"
    elif alert_engine.check("fever", temp>=38.3):
        ai_var.set("FEVER"); ai_label_w.config(fg=WARN)
        alert_msg = f"Sot: {temp:.1f}C"
    elif alert_engine.check("spo2_low", spo2>0 and spo2<94):
        ai_var.set("SpO2 LOW"); ai_label_w.config(fg=WARN)
        alert_msg = f"SpO2 thap: {spo2:.1f}%"
    elif alert_engine.check("ai_risk", label=="RISK" and conf>60):
        ai_var.set(f"HIGH RISK {conf}%"); ai_label_w.config(fg=ACC2)
        alert_msg = f"AI nguy co cao ({conf}%)"
    else:
        if label=="RISK": ai_var.set(f"MOD RISK {conf}%"); ai_label_w.config(fg=WARN)
        else:             ai_var.set(f"NORMAL {conf}%");   ai_label_w.config(fg=GREEN)

    conds = {"spo2_crit":"SpO2 CRIT","sepsis":"Sepsis","tachy":"HR UP",
             "brady":"HR DOWN","hypo_temp":"Temp LOW","fever":"Fever",
             "spo2_low":"SpO2 LOW","ai_risk":"AI RISK"}
    active = [f"{v} {alert_engine.elapsed(k):.0f}s"
              for k,v in conds.items() if alert_engine.elapsed(k)>0]
    timer_var.set("  ".join(active))

    if alert_msg:
        root.after(0, lambda m=alert_msg, n=pname, p=pphone: _do_alert(m,n,p))

def _do_alert(msg, pname, phone):
    try: winsound.Beep(1000, 600)
    except: pass
    messagebox.showwarning("ALERT", f"Benh nhan: {pname}\n{msg}")
    notify_all(pname, msg, phone)

