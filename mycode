current_csv = current_writer = session_start = None
history = []

def start_session(pname, pid):
    global current_csv, current_writer, session_start, history
    history = []; session_start = datetime.now()
    safe   = "".join(c for c in pname if c.isalnum() or c in " _-")
    folder = DATA_DIR / f"P{pid:04d}_{safe}"
    folder.mkdir(exist_ok=True)
    fname  = folder / f"{session_start.strftime('%Y%m%d_%H%M%S')}.csv"
    current_csv    = open(fname, "w", newline="", encoding="utf-8-sig")
    current_writer = csv.writer(current_csv)
    current_writer.writerow(["Time","HR","SpO2","Temp","PPG","PI","AI_Label","Confidence"])

def write_row(hr, spo2, temp, ppg, pi, label, conf):
    if current_writer:
        current_writer.writerow([datetime.now().strftime("%H:%M:%S"),
            hr, spo2, f"{temp:.1f}", ppg, f"{pi:.2f}", label, conf])
        current_csv.flush()

def end_session(pid):
    global current_csv, current_writer
    if current_csv: current_csv.close()
    current_csv = current_writer = None
    if history and session_start:
        hrs   = [h[1] for h in history]
        spo2s = [h[2] for h in history]
        temps = [h[3] for h in history]
        risks = [h for h in history if h[4]=="RISK"]
        rr    = len(risks)/len(history)*100 if history else 0
        save_session(pid,
            session_start.strftime("%Y-%m-%d %H:%M:%S"),
            datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
            float(np.mean(hrs)), float(np.mean(spo2s)),
            float(np.mean(temps)), rr,
            "HIGH RISK" if rr>30 else "LOW RISK")

