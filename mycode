#  SUSTAINED ALERT ENGINE
# ================================================================
class SustainedAlert:
    def __init__(self, confirm_sec=CONFIRM_SEC):
        self.confirm_sec = confirm_sec
        self._timers = {}; self._last_alert = {}

    def check(self, name, condition):
        now = time.time()
        if condition:
            if name not in self._timers: self._timers[name] = now
            if (now - self._timers[name] >= self.confirm_sec and
                    now - self._last_alert.get(name, 0) >= ALERT_COOLDOWN):
                self._last_alert[name] = now; return True
        else:
            self._timers.pop(name, None)
        return False

    def elapsed(self, name):
        return time.time() - self._timers[name] if name in self._timers else 0.0

    def reset_all(self):
        self._timers.clear(); self._last_alert.clear()

alert_engine = SustainedAlert()

# ================================================================
#  PERSONALIZED BASELINE
# ================================================================
class PersonalizedBaseline:
    CALIBRATION_N = 60
    def __init__(self):
        self._buf = {"hr":[],"spo2":[],"temp":[],"pi":[]}
        self.baseline = {"hr":70,"spo2":98,"temp":36.6,"pi":5.0}
        self.calibrated = False; self.n = 0

    def update(self, hr, spo2, temp, pi):
        if self.calibrated: return
        for k,v in zip(["hr","spo2","temp","pi"],[hr,spo2,temp,pi]):
            self._buf[k].append(v)
        self.n += 1
        if self.n >= self.CALIBRATION_N:
            self.baseline   = {k:float(np.median(v)) for k,v in self._buf.items()}
            self.calibrated = True

    def reset(self): self.__init__()

    @property
    def status(self):
        return "Calibrated" if self.calibrated else f"Calibrating {self.n}/{self.CALIBRATION_N}"

baseline_engine = PersonalizedBaseline()

# ================================================================
#  FEATURE ENGINEERING
# ================================================================
def extract_features(ppg, hr, spo2, temp, baseline):
    sig = np.array(ppg, dtype=float)
    dc  = np.mean(sig) + 1e-6
    pi  = np.std(sig) / dc * 100
    pv  = np.std(np.diff(sig))
    peaks, _ = find_peaks(sig, distance=int(SAMPLE_RATE*0.4))
    ptt = np.mean(np.diff(peaks))/SAMPLE_RATE if len(peaks)>=2 else 0.0
    return np.array([
        hr/200, spo2/100, (temp-35)/5, pi/20, pv/1000, ptt,
        float(skew(sig))/3, float(kurtosis(sig))/10,
        float(np.max(sig)-np.min(sig))/50000,
        max(0,98-spo2)/20, hr/(spo2*0.8+1e-6)/2,
        (hr-baseline.get("hr",70))/50,
        (spo2-baseline.get("spo2",98))/10,
        (temp-baseline.get("temp",36.6))/3,
        (pi-baseline.get("pi",5))/10
    ], dtype=np.float32)

# ================================================================
#  AI PREDICT
# ================================================================
ppg_buffer = deque(maxlen=WINDOW)
ai_history = deque(maxlen=5)

def hybrid_predict(ppg, hr, spo2, temp):
    ppg_buffer.append(ppg)
    if len(ppg_buffer) < WINDOW: return "COLLECTING", 0
    sig      = np.array(ppg_buffer, dtype=np.float32)
    pi       = np.std(sig)/(np.mean(sig)+1e-6)*100
    baseline_engine.update(hr, spo2, temp, pi)
    features = extract_features(sig, hr, spo2, temp, baseline_engine.baseline)
    ppg_norm = (sig-np.mean(sig))/(np.std(sig)+1e-6)
    ppg_in   = ppg_norm.reshape(1, WINDOW, 1)
    try:
        dl_pred = dl_model.predict(
            [ppg_in, features.reshape(1,-1)]
            if dl_model and len(dl_model.inputs)==2 else ppg_in, verbose=0)
        dl_risk = float(dl_pred[0][1]) if dl_model else 0.5
    except: dl_risk = 0.5
    try:
        xgb_risk = float(xgb_model.predict_proba(
            features.reshape(1,-1))[0][1]) if xgb_model else dl_risk
    except: xgb_risk = dl_risk
    risk  = 0.6*dl_risk + 0.4*xgb_risk
    label = "RISK" if risk > 0.5 else "NORMAL"
    ai_history.append(label)
    label = "RISK" if ai_history.count("RISK") >= 4 else "NORMAL"
    return label, int(risk*100)

