def _update_plot(ppg_val):
    global ppg_plot
    ppg_plot     = np.roll(ppg_plot, -1)
    ppg_plot[-1] = float(ppg_val)
    line_ppg.set_ydata(ppg_plot)
    valid = ppg_plot[ppg_plot > 0]
    if len(valid) > 10:
        lo,hi = valid.min(), valid.max()
        ax.set_ylim(lo-(hi-lo)*0.15-1, hi+(hi-lo)*0.15+1)
    canvas.draw_idle()

