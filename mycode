def connect():
    global ser, running
    if not current_patient:
        if not messagebox.askyesno("Chua chon benh nhan",
                                    "Tiep tuc do ma khong luu ho so?"): return
    try:
        ser     = serial.Serial(port_var.get(), BAUDRATE, timeout=1)
        running = True
        status_var.set("LIVE")
        baseline_engine.reset(); alert_engine.reset_all()
        if current_patient: start_session(current_patient[1], current_patient[0])
        threading.Thread(target=read_serial, daemon=True).start()
    except Exception as e:
        messagebox.showerror("Loi ket noi", str(e))

def disconnect():
    global ser, running
    running = False
    if ser and ser.is_open: ser.close()
    status_var.set("OFFLINE")
    ppg_buffer.clear(); ai_history.clear()
    baseline_engine.reset(); alert_engine.reset_all()
    if current_patient:
        end_session(current_patient[0])
        refresh_hs_combo()

def read_serial():
    global last_temp
    while running:
        try:
            raw = ser.readline().decode(errors="ignore").strip()
            if not raw: continue
            pkt = json.loads(raw)
            if "event" in pkt: continue

            finger = pkt.get("finger", False)
            hr     = float(pkt.get("hr",   0))
            spo2   = float(pkt.get("spo2", 0))
            ppg    = float(pkt.get("ppg",  0))
            t      = float(pkt.get("temp", 0))
            if t > 25.0 and t < 45.0: last_temp = t

            if hr>0 and (hr<20 or hr>250): continue
            if spo2>0 and (spo2<50 or spo2>100): continue
            if ppg < 1000: continue

            label, conf = hybrid_predict(ppg, hr, spo2, last_temp)

            root.after(0, lambda p=ppg: _update_plot(p))
            root.after(0, lambda f=finger, h=hr, s=spo2, p=ppg,
                          lb=label, c=conf, t=last_temp:
                          update_gui(f, h, s, p, lb, c, t))

            sig = np.array(ppg_buffer) if len(ppg_buffer)==WINDOW else np.zeros(WINDOW)
            pi  = np.std(sig)/(np.mean(sig)+1e-6)*100
            write_row(hr, spo2, last_temp, ppg, pi, label, conf)
            history.append([time.time(), hr, spo2, last_temp, label, conf])

        except Exception as e:
            print("ERR:", e)

